# Configuração da plataforma barelli.automacao
# Copie para .env e ajuste conforme necessário. Prefixo das variáveis: BARELLI_

# Porta do servidor web
BARELLI_PORT=8000

# Autenticação (mantida desativada nesta fase)
BARELLI_AUTH_ENABLED=false

# Origens liberadas no CORS (JSON). Ex.: o Vite dev server
BARELLI_CORS_ORIGINS=["http://localhost:5173"]

# Diretório de dados/perfis (opcional). Vazio = usa a pasta profiles/ na raiz,
# compartilhada com o app desktop.
# BARELLI_DATA_DIR=
